# =============================================================================
# BmsSiteOps — PRODUCTION environment template
# =============================================================================
# Copy this file to .env on the production host and fill in real values:
#
#     cp infra/compose/.env.prod.example .env
#
# The .env file is gitignored and MUST NEVER be committed. Every value marked
# CHANGEME or left blank below must be set before `make prod-up`.
#
# Generate strong secrets with:
#     openssl rand -base64 32
#
# This template contains NO real credentials, hostnames, or IPs — only
# placeholders. It is safe to keep in the public repository.
# =============================================================================

# --- Application meta --------------------------------------------------------
APP_NAME="BmsSiteOps"
APP_ENV=production
APP_DEBUG=false                          # MUST be false in production
APP_URL=https://<YOUR_DOMAIN>            # e.g. https://ops.example.com
APP_TIMEZONE=UTC
APP_KEY=                                  # php artisan key:generate --show

# --- Public hostnames (used by Caddy for automatic HTTPS) --------------------
WEB_HOST=<YOUR_DOMAIN>                    # main web + API host, e.g. ops.example.com
API_HOST=<YOUR_DOMAIN>                    # same domain in prod (API served under /api)
MCP_HOST=<YOUR_MCP_DOMAIN>               # MCP endpoint, e.g. ops-mcp.example.com

# --- MCP endpoint hardening (Sprint 8.5) -------------------------------------
# IP allowlist: space-separated CIDRs that may reach the MCP host. Default is
# the wildcard "0.0.0.0/0 ::/0" (unrestricted), so existing deploys are
# backward compatible. Restrict in production by setting, e.g.:
#
#     MCP_IP_ALLOWLIST="10.0.0.0/8 198.51.100.0/24 2001:db8::/32"
#
# Multiple CIDRs are separated by single spaces (NOT commas — Caddy's
# remote_ip matcher uses space-separated lists).
MCP_IP_ALLOWLIST=0.0.0.0/0 ::/0

# HTTP Basic Auth (optional, off by default). To enable:
#   1. Replace infra/caddy/mcp-basic-auth.conf with the .example template
#   2. Generate a hash with: make mcp-gen-credentials
#   3. Set MCP_BASIC_AUTH_HASH below to the hash
#   4. Restart caddy: make prod-restart
# When the stub conf is in place (default), this env is unused.
MCP_BASIC_AUTH_HASH=

# Rate limit on the MCP host — requests per minute per client IP. Sized for
# human-paced Claude Desktop / Cursor traffic (~5-10 req/min during active
# use); excess requests get a 429 response. Caps brute-force attempts
# against basic_auth: 30/min = 5 wrong passwords every 10 seconds.
# Requires the custom Caddy build (infra/docker/caddy.Dockerfile) which the
# prod compose already wires up.
MCP_RATE_LIMIT_PER_MIN=30
ADMIN_PATH=/admin
ACME_EMAIL=<YOUR_EMAIL>                  # Let's Encrypt registration email

# --- Database (PostgreSQL) ---------------------------------------------------
# In production the database is NOT exposed to the host. These values are
# consumed by both the postgres container and the api/worker containers.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bmssiteops
DB_USERNAME=bmssiteops
DB_PASSWORD=CHANGEME                      # openssl rand -base64 32

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# --- Driver selection --------------------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb

# --- Meilisearch -------------------------------------------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=CHANGEME                  # openssl rand -base64 32

# --- Laravel Reverb (WebSockets) ---------------------------------------------
REVERB_APP_ID=bmssiteops
REVERB_APP_KEY=CHANGEME
REVERB_APP_SECRET=CHANGEME
REVERB_HOST=<YOUR_DOMAIN>
REVERB_PORT=443
REVERB_SCHEME=https

# --- Mail --------------------------------------------------------------------
MAIL_MAILER=smtp                          # smtp | resend | postmark | log
MAIL_FROM_ADDRESS="<YOUR_EMAIL>"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_HOST=<YOUR_SMTP_HOST>
MAIL_PORT=587
MAIL_USERNAME=<YOUR_SMTP_USER>
MAIL_PASSWORD=CHANGEME
MAIL_ENCRYPTION=tls

# --- AI / LiteLLM ------------------------------------------------------------
# LiteLLM proxy — sits in front of every LLM and embedding vendor.
# Two deployment modes (see infra/litellm/README.md):
#   * external proxy (e.g. on BOLDNJPC AI workstation) — set the URL to it
#   * self-contained (run with `COMPOSE_PROFILES=litellm make prod-up`)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=CHANGEME               # openssl rand -base64 32
ANTHROPIC_API_KEY=                        # sk-ant-... (required for Claude routing)
OPENAI_API_KEY=                           # sk-... (optional fallback)

# Ollama host (used by litellm to route 'ollama/*' models).
# `host.docker.internal` works on Docker Desktop AND on Linux thanks to the
# extra_hosts entry in the litellm service; for a remote workstation, set
# this to its LAN IP, e.g. http://10.0.0.42:11434.
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_HOST=${OLLAMA_API_BASE}            # legacy alias kept for compatibility

# Default model selection. Briefs + Q&A answers use DEFAULT_AI_MODEL;
# Script Authoring + RAG embeddings use the local ones via LiteLLM routing.
DEFAULT_AI_MODEL=claude-sonnet-4-5
LOCAL_AI_MODEL=qwen2.5-coder:32b
EMBEDDING_MODEL=ollama/nomic-embed-text

# --- Worker (Python FastAPI) -------------------------------------------------
WORKER_BASE_URL=http://worker:8000
WORKER_INTERNAL_KEY=CHANGEME              # openssl rand -base64 32 (shared with api)

# --- Per-tenant data-source configs live in the database, not here. ----------
# These are only fallback defaults for single-tenant bootstrap.
TRMM_BASE_URL=
TRMM_API_TOKEN=
NIAGARA_FOX_HOST=
NIAGARA_FOX_PORT=1911
NIAGARA_FOX_USERNAME=
NIAGARA_FOX_PASSWORD=

# --- Observability (optional) ------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
