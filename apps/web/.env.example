# SvelteKit reads variables prefixed with PUBLIC_ at build time and exposes
# them to client code via $env/static/public. Anything else stays server-side.
#
# Copy this file to .env when running locally:
#   cp .env.example .env
#
# In production, environment variables are injected by docker-compose from
# the monorepo root .env file (see infra/compose/docker-compose.prod.yml).

# --- Public (safe to send to the browser) -----------------------------------
PUBLIC_API_BASE_URL=http://localhost:8080
PUBLIC_APP_NAME="BmsSiteOps"

# --- Private (server-only; available via $env/static/private) ---------------
# SESSION_SECRET=changeme
