# ============================================================================
# BmsSiteOps — environment variable template
# ============================================================================
# Copy this file to .env and fill in values. The .env file is gitignored and
# MUST NOT be committed. Anything sensitive belongs only in .env.
# ============================================================================

# --- Application meta ---
APP_NAME="BmsSiteOps"
APP_ENV=local                            # local | staging | production
APP_DEBUG=true                           # MUST be false in production
APP_URL=http://localhost
APP_TIMEZONE=America/New_York
APP_KEY=                                 # generate via: php artisan key:generate

# --- Public hostnames ---
WEB_HOST=ops.local                       # SvelteKit UI hostname (prod: ops.bmssiteops.com)
API_HOST=ops.local                       # Laravel API hostname (same domain in prod, /api prefix)
MCP_HOST=ops-mcp.local                   # MCP endpoint hostname (prod: ops-mcp.bmssiteops.com)
ADMIN_PATH=/admin                        # Filament admin panel path
ACME_EMAIL=ops@bmssiteops.com            # Let's Encrypt account email for production Caddy

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bmssiteops
DB_USERNAME=bmssiteops
DB_PASSWORD=changeme                     # MUST be changed in production

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# --- Queue / cache / session driver ---
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb

# --- Meilisearch ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=changeme                 # MUST be changed in production

# --- Laravel Reverb (WebSockets) ---
REVERB_APP_ID=bmssiteops
REVERB_APP_KEY=changeme
REVERB_APP_SECRET=changeme
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Mail ---
MAIL_MAILER=log                          # log | smtp | resend | postmark
MAIL_FROM_ADDRESS="ops@bmssiteops.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# --- AI / LiteLLM ---
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=changeme              # MUST be changed in production
ANTHROPIC_API_KEY=                       # required for Claude routing
OLLAMA_HOST=http://host.docker.internal:11434
DEFAULT_AI_MODEL=claude-sonnet-4-5       # routing default; per-job models can override
LOCAL_AI_MODEL=qwen2.5-coder:32b         # Qwen 2.5 Coder via Ollama for batch jobs

# --- Worker (Python FastAPI) ---
WORKER_BASE_URL=http://worker:8000
WORKER_INTERNAL_KEY=changeme             # shared secret between api and worker

# --- TRMM data source (per-tenant configs live in DB, this is the dev default) ---
TRMM_BASE_URL=
TRMM_API_TOKEN=

# --- Niagara data source (dev default) ---
NIAGARA_FOX_HOST=
NIAGARA_FOX_PORT=1911
NIAGARA_FOX_USERNAME=
NIAGARA_FOX_PASSWORD=

# --- Sentry / observability (optional) ---
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
